# Copy this file to .env and edit before running docker compose.
# docker compose reads .env automatically.

# Absolute path to the folder containing your GeoMx TIFF files.
# This is bind-mounted to /data inside the container.
# Paste "/data" into the "Folder path" sidebar field when the app loads.
GEOMX_DATA_DIR=/path/to/your/geomx/tiff/folder

# Host port the dashboard will be available on.
# Access the app at http://localhost:<GEOMX_PORT>
GEOMX_PORT=8501
